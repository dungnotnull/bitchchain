# Bitchchain Agent — Required Environment Variables
# Copy to .env and fill in your values. Never commit .env to version control.

# ─── LLM API Keys ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...           # Claude API key (primary LLM)
OPENAI_API_KEY=sk-...                  # OpenAI API key (fallback LLM)
OLLAMA_BASE_URL=http://localhost:11434  # Ollama server URL (offline/privacy mode)

# ─── Node Configuration ───────────────────────────────────────────────────────
BITCHCHAIN_NETWORK=mainnet             # mainnet | testnet | regtest
BITCHCHAIN_MINER_ADDRESS=             # BCC address to receive coinbase rewards
BITCHCHAIN_P2P_PORT=8333
BITCHCHAIN_RPC_PORT=8332
BITCHCHAIN_MAX_PEERS=8

# ─── Storage ──────────────────────────────────────────────────────────────────
CHAIN_DB_PATH=chain.db
AGENT_DB_PATH=agent_memory.db
MODELS_CACHE_DIR=models

# ─── Research Crawler ─────────────────────────────────────────────────────────
SEMANTIC_SCHOLAR_API_KEY=             # Optional — increases rate limit
KNOWLEDGE_UPDATER_SCHEDULE=0 2 * * 0  # Cron: weekly Sunday 02:00 UTC

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/bitchchain.log
